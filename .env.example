# Copy to `.env` and fill in. `.env` is gitignored.

# --- App under test ---
BASE_URL=http://localhost:3000
POCKETBASE_PROXY=/hcgi/platform
POCKETBASE_DIRECT=http://localhost:8090

# --- Test user (customer-facing). Create via API/seed; do NOT use admin creds. ---
TEST_USER_EMAIL=
TEST_USER_PASSWORD=

# --- Execution ---
ENV=local
BROWSER=chromium
HEADED=1

# --- Optional AI healer (leave blank to run deterministic-only) ---
ANTHROPIC_API_KEY=
AI_HEALING_ENABLED=false
